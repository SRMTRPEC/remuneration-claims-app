{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/admin/dashboard",
      "dest": "/frontend/admin/dashboard.html"
    },
    {
      "src": "/admin/claims",
      "dest": "/frontend/admin/claims.html"
    },
    {
      "src": "/admin/claim/.*",
      "dest": "/frontend/admin/claim-detail.html"
    },
    {
      "src": "/admin/?",
      "dest": "/frontend/admin/login.html"
    },
    {
      "src": "/login",
      "dest": "/frontend/staff-login.html"
    },
    {
      "src": "/register",
      "dest": "/frontend/staff-register.html"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
